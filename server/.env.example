PORT=3004
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=newapi_user
DB_PASSWORD=change_me
DB_NAME=newapi
DB_CONNECTION_LIMIT=10
# You can also reuse New API's Go-style SQL_DSN instead of DB_*:
# SQL_DSN=root:password@tcp(127.0.0.1:3306)/newapi?parseTime=true
# Keep authentication on MySQL while storing generation recovery jobs locally.
GENERATION_DB_DRIVER=sqlite
GENERATION_SQLITE_PATH=./data/generation-jobs.sqlite
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=30d
ALLOW_PASSWORD_REGISTER=false
NEW_API_KEY_PREFIX=sk-
